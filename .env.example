# Required
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Google OAuth (for Gmail + Calendar)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Account 1
GOOGLE_ACCOUNT_1_NAME=work
GOOGLE_ACCOUNT_1_EMAIL=you@company.com
GOOGLE_ACCOUNT_1_REFRESH_TOKEN=

# Google Account 2 (optional)
GOOGLE_ACCOUNT_2_NAME=personal
GOOGLE_ACCOUNT_2_EMAIL=you@gmail.com
GOOGLE_ACCOUNT_2_REFRESH_TOKEN=

# Amadeus Flight Search (optional)
# Get keys at https://developers.amadeus.com
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
